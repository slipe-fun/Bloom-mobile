{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "jsx": "react-native",
    "strict": false,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "allowJs": true,
    "checkJs": false,
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@constants/*": ["src/constants/*"],
      "@assets/*": ["assets/*"],
      "@hooks": ["src/hooks"],
      "@stores/*": ["src/stores/*"],
      "@screens": ["src/screens"],
      "@lib/*": ["src/lib/*"],
      "@interfaces": ["src/interfaces/index"],
      "@api/*": ["src/api/*"],
      "@app/*": ["app/*"],
      "@layouts/*": ["layouts/*"],
      "@providers/*": ["src/providers/*"],
      "@services/*": ["src/services/*"],
      "@design/*": ["src/design/*"],
      "@modules/*": ["modules/*"]
    },
    "isolatedModules": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": false,
    "useDefineForClassFields": false
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "src/api/providers/WebSocketContext.js",
    "modules/hybrid-list-view/src/HybridListViewModule.tsx"
  ],
  "exclude": ["node_modules", "babel.config.js", "metro.config.js"]
}
